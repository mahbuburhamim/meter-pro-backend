# NESCO Balance Tracker Environment Variables Template

# 1. DATABASE
# Connection URL for PostgreSQL.
# Example: postgresql://username:password@localhost:5432/nescodb
# (For local development, SQLite is used by default if this is empty)
DATABASE_URL=

# 2. TELEGRAM ALERTS (Optional but recommended for notifications)
# Token of the Telegram Bot used to send balance alerts.
# Example: 123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_BOT_TOKEN=
# Chat ID of the user or group who will receive the alerts.
# Example: 987654321
TELEGRAM_CHAT_ID=

# 3. CORS ORIGINS
# Comma-separated list of allowed frontend origins.
# Use '*' to allow all origins (default), or restrict it to your deployed frontend app.
# Example: https://nesco-tracker.onrender.com,http://localhost:3000
FRONTEND_ORIGIN=*

# 4. CRON AUTHENTICATION
# Shared secret token to authorize external cron tasks triggering /api/refresh-all.
# Create a secure random string for this value.
# Example: MySuperSecureCronSecretToken123!
CRON_SECRET=
